<!DOCTYPE html>
<html lang="en">
<head>
    <title>Universal Registration Form</title>
</head>
<body>

<h1>Universal Registration & Management Form</h1>

<form>

    <!-- Personal Details -->
    <fieldset>
        <legend>Personal Details</legend>

        <label>Full Name:</label>
        <input type="text" placeholder="Enter Full Name" required><br><br>

        <label>Email:</label>
        <input type="email" placeholder="Enter Email" required><br><br>

        <label>Phone Number:</label>
        <input type="tel" placeholder="Enter Phone Number" required><br><br>

        <label>Date of Birth:</label>
        <input type="date" required><br><br>

        <label>Gender:</label>
        <input type="radio" name="gender"> Male
        <input type="radio" name="gender"> Female
        <input type="radio" name="gender"> Other<br><br>

        <label>Marital Status:</label>
        <input type="text" placeholder="Single / Married"><br><br>
    </fieldset>

    <!-- Education Details -->
    <fieldset>
        <legend>Education Details</legend>

        <label>Highest Qualification:</label>
        <input type="text" placeholder="Enter Qualification" required><br><br>

        <label>College Name:</label>
        <input type="text" placeholder="Enter College Name" required><br><br>

        <label>Year of Passing:</label>
        <input type="number" placeholder="Year" required><br><br>

        <label>Percentage:</label>
        <input type="number" placeholder="Enter %" required><br><br>
    </fieldset>

    <!-- Professional Details -->
    <fieldset>
        <legend>Professional Details</legend>

        <label>Experience (Years):</label>
        <input type="number" placeholder="Experience"><br><br>

        <label>Skills:</label>
        <input type="checkbox"> HTML
        <input type="checkbox"> CSS
        <input type="checkbox"> JavaScript
        <input type="checkbox"> Python
        <input type="checkbox"> React<br><br>

        <label>Current Company:</label>
        <input type="text" placeholder="Company Name"><br><br>

        <label>Expected Salary:</label>
        <input type="number" placeholder="Salary"><br><br>
    </fieldset>

    <!-- Account Setup -->
    <fieldset>
        <legend>Account Setup</legend>

        <label>Username:</label>
        <input type="text" placeholder="Enter Username" required><br><br>

        <label>Password:</label>
        <input type="password" placeholder="Enter Password" required><br><br>

        <label>Confirm Password:</label>
        <input type="password" placeholder="Re-enter Password" required><br><br>

        <label>Security Question:</label>
        <input type="text" placeholder="Your Pet Name?"><br><br>

        <label>Answer:</label>
        <input type="text" placeholder="Enter Answer"><br><br>
    </fieldset>

    <!-- Address Details -->
    <fieldset>
        <legend>Address Details</legend>

        <label>Address Line:</label>
        <input type="text" placeholder="Enter Address" required><br><br>

        <label>City:</label>
        <input type="text" placeholder="City"><br><br>

        <label>State:</label>
        <input type="text" placeholder="State"><br><br>

        <label>Pincode:</label>
        <input type="number" placeholder="Pincode"><br><br>

        <label>Country:</label>
        <input type="text" placeholder="Country"><br><br>
    </fieldset>

    <!-- Emergency Contact -->
    <fieldset>
        <legend>Emergency Contact</legend>

        <label>Contact Person Name:</label>
        <input type="text" placeholder="Name"><br><br>

        <label>Relationship:</label>
        <input type="text" placeholder="Relationship"><br><br>

        <label>Emergency Phone:</label>
        <input type="tel" placeholder="Phone Number"><br><br>
    </fieldset>

    <!-- Upload Documents -->
    <fieldset>
        <legend>Upload Documents</legend>

        <label>Upload Resume:</label>
        <input type="file"><br><br>

        <label>Upload Profile Photo:</label>
        <input type="file"><br><br>
    </fieldset>

    <!-- Declaration -->
    <fieldset>
        <legend>Declaration</legend>

        <input type="checkbox" required> I hereby declare that the above information is true and correct.
    </fieldset>

    <br>
    <button type="submit">Submit Registration</button>
    <button type="reset">Reset Form</button>

</form>

</body>
</html>
