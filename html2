<!DOCTYPE html>
<html lang="en">
<head>
    <title>LifeCare Hospital</title>
</head>
<body>

    <!-- Header -->
    <h1>LifeCare Multi-Speciality Hospital</h1>
    <nav>
        <a href="#">Home</a> |
        <a href="#">About</a> |
        <a href="#">Doctors</a> |
        <a href="#">Services</a> |
        <a href="#">Appointment</a> |
        <a href="#">Contact</a>
    </nav>
    <hr>

    <!-- Welcome Section -->
    <h2>Welcome to LifeCare Hospital</h2>
    <img src="hospital.jpg" alt="Hospital Image" width="300">
    <p>We provide quality healthcare services with modern facilities and experienced doctors.</p>

    <!-- About Us -->
    <h2>About Us</h2>
    <p>LifeCare Hospital is a leading healthcare provider offering world-class treatment.</p>
    <p>Our mission is to provide affordable and advanced medical care to everyone.</p>

    <!-- Doctors -->
    <h2>Our Doctors</h2>
    <ul>
        <li>Dr. Arun – Cardiologist</li>
        <li>Dr. Meena – Neurologist</li>
        <li>Dr. Karthik – Orthopedic</li>
        <li>Dr. Priya – Pediatrician</li>
    </ul>

    <!-- Services -->
    <h2>Our Services</h2>
    <ol>
        <li>Emergency Care</li>
        <li>24/7 Pharmacy</li>
        <li>Laboratory Services</li>
        <li>ICU & Operation Theatre</li>
    </ol>

    <!-- Timings -->
    <h2>Hospital Timings</h2>
    <table border="1">
        <tr>
            <th>Day</th>
            <th>Opening Time</th>
            <th>Closing Time</th>
        </tr>
        <tr>
            <td>Monday - Friday</td>
            <td>8:00 AM</td>
            <td>8:00 PM</td>
        </tr>
        <tr>
            <td>Saturday</td>
            <td>9:00 AM</td>
            <td>5:00 PM</td>
        </tr>
        <tr>
            <td>Sunday</td>
            <td colspan="2">Emergency Only</td>
        </tr>
    </table>

    <!-- Appointment Form -->
    <h2>Book an Appointment</h2>
    <form>
        <label>Full Name:</label><br>
        <input type="text" placeholder="Enter your name"><br><br>

        <label>Email:</label><br>
        <input type="email" placeholder="Enter your email"><br><br>

        <label>Phone:</label><br>
        <input type="tel" placeholder="10-digit number"><br><br>

        <label>Gender:</label><br>
        <input type="radio" name="gender"> Male
        <input type="radio" name="gender"> Female
        <input type="radio" name="gender"> Other<br><br>

        <label>Select Department:</label><br>
        <select>
            <option>--Select--</option>
            <option>Cardiology</option>
            <option>Neurology</option>
            <option>Orthopedic</option>
            <option>Pediatrics</option>
        </select><br><br>

        <label>Appointment Date:</label><br>
        <input type="date"><br><br>

        <label>Upload Medical Report:</label><br>
        <input type="file"><br><br>

        <label>Message:</label><br>
        <textarea placeholder="Describe your issue"></textarea><br><br>

        <button type="submit">Book Appointment</button>
        <button type="reset">Clear Form</button>
    </form>

    <!-- Contact -->
    <h2>Contact Us</h2>
    <p>Email: info@lifecare.com</p>
    <p>Phone: +91 9876543210</p>

    <!-- Footer -->
    <hr>
    <p>© 2026 LifeCare Hospital. All Rights Reserved.</p>

</body>
</html>
