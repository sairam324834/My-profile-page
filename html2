<!DOCTYPE html>
<html>
<head>
    <title>Universal Registration Form</title>
</head>
<body>

    <h1>Universal Registration & Management Form</h1>
    <hr>

    <form>

        <!-- Personal Details -->
        <fieldset>
            <legend><b>Personal Details</b></legend>

            Full Name: <input type="text"><br><br>
            Email: <input type="email"><br><br>
            Phone Number: <input type="text"><br><br>
            Date of Birth: <input type="date"><br><br>

            Gender:
            <input type="radio" name="gender"> Male
            <input type="radio" name="gender"> Female
            <input type="radio" name="gender"> Other
            <br><br>

            Marital Status:
            <select>
                <option>--Select--</option>
                <option>Single</option>
                <option>Married</option>
            </select>
        </fieldset>

        <br>

        <!-- Education Details -->
        <fieldset>
            <legend><b>Education Details</b></legend>

            Highest Qualification:
            <select>
                <option>--Select Qualification--</option>
                <option>B.Tech</option>
                <option>M.Tech</option>
                <option>Degree</option>
            </select>
            <br><br>

            College Name: <input type="text"><br><br>
            Year of Passing: <input type="text"><br><br>
            Percentage: <input type="text">
        </fieldset>

        <br>

        <!-- Professional Details -->
        <fieldset>
            <legend><b>Professional Details</b></legend>

            Experience (Years): <input type="text"><br><br>

            Skills:
            <input type="checkbox"> HTML
            <input type="checkbox"> CSS
            <input type="checkbox"> JavaScript
            <input type="checkbox"> Python
            <input type="checkbox"> React
            <br><br>

            Current Company: <input type="text"><br><br>
            Expected Salary: <input type="text">
        </fieldset>

        <br>

        <!-- Account Setup -->
        <fieldset>
            <legend><b>Account Setup</b></legend>

            Username: <input type="text"><br><br>
            Password: <input type="password"><br><br>
            Confirm Password: <input type="password"><br><br>

            Security Question:
            <select>
                <option>Your Pet Name?</option>
                <option>Your Birthplace?</option>
            </select>
            <br><br>

            Answer: <input type="text">
        </fieldset>

        <br>

        <!-- Address Details -->
        <fieldset>
            <legend><b>Address Details</b></legend>

            Address Line:<br>
            <textarea rows="4" cols="50"></textarea><br><br>

            City: <input type="text"><br><br>
            State: <input type="text"><br><br>
            Pincode: <input type="text"><br><br>
            Country: <input type="text">
        </fieldset>

        <br>

        <!-- Emergency Contact -->
        <fieldset>
            <legend><b>Emergency Contact</b></legend>

            Contact Person Name: <input type="text"><br><br>
            Relationship: <input type="text"><br><br>
            Emergency Phone: <input type="text">
        </fieldset>

        <br>

        <!-- Upload Documents -->
        <fieldset>
            <legend><b>Upload Documents</b></legend>

            Upload Resume: <input type="file"><br><br>
            Upload Profile Photo: <input type="file">
        </fieldset>

        <br>

        <!-- Declaration -->
        <fieldset>
            <legend><b>Declaration</b></legend>

            <input type="checkbox">
            I hereby declare that the above information is true and correct.
        </fieldset>

        <br>

        <input type="submit" value="Submit Registration">
        <input type="reset" value="Reset Form">

    </form>

    <hr>
    <p>&copy; 2026 Universal Registration System</p>

</body>
</html>
